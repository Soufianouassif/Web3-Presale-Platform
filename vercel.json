{
  "installCommand": "pnpm install",
  "buildCommand": "chmod +x scripts/vercel-build.sh && sh scripts/vercel-build.sh",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/server.mjs": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "api/**"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/server" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
