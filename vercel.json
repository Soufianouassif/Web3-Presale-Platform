{
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "node artifacts/api-server/build.mjs && pnpm --filter @workspace/pepewife run build",
  "outputDirectory": "artifacts/pepewife/dist",
  "framework": null,
  "functions": {
    "api/index.mjs": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.mjs" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
