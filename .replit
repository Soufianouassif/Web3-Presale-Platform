modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
ADMIN_EMAILS = "soufian1122a@gmail.com"

[userenv.production]
FRONTEND_URL = "https://www.pwifecoin.fun"
VERCEL_PREVIEW_DOMAIN = "pwifecoin.fun"
GOOGLE_CALLBACK_URL = "https://www.pwifecoin.fun/api/auth/google/callback"
SOLANA_RPC_URL = "https://api.devnet.solana.com"

[userenv.development]
GOOGLE_CALLBACK_URL = "http://localhost:8080/api/auth/google/callback"
SOLANA_RPC_URL = "https://api.devnet.solana.com"
