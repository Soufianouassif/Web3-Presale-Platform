{
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "node ./build.mjs && pnpm --filter @workspace/pepewife run build && mkdir -p frontend_dist && cp -r ../pepewife/dist/. frontend_dist/",
  "outputDirectory": "frontend_dist",
  "framework": null,
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
